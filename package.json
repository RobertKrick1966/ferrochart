{
  "name": "ferrochart",
  "version": "0.1.0",
  "description": "High-performance financial charting library built in Rust/WASM",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/RobertKrick1966/ferrochart"
  },
  "type": "module",
  "main": "pkg/ferrochart_wasm.js",
